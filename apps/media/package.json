{
  "name": "@interestshield/media",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "check": "npm run test:contracts && npm run check:hyperframes && npm run check:remotion",
    "test:contracts": "node --test scripts/*.test.mjs",
    "check:hyperframes": "node scripts/check-hyperframes.mjs",
    "check:remotion": "node scripts/check-remotion.mjs",
    "generate:scenarios": "tsx scripts/generate-remotion-scenarios.ts",
    "map:hyperframes": "node scripts/map-hyperframes.mjs",
    "prepare:hyperframes": "node scripts/prepare-hyperframes-assets.mjs",
    "prepare:remotion-browser": "node scripts/prepare-remotion-browser.mjs",
    "prepare:remotion": "node scripts/prepare-remotion-assets.mjs",
    "render:still": "npm run prepare:remotion && node scripts/remotion-cli.mjs still remotion/src/index.ts InterestShield-Scenario-Still remotion/out/representative-still.png --public-dir=remotion/public --overwrite",
    "render:matrix": "node scripts/render-remotion-matrix.mjs",
    "render:video": "npm run prepare:remotion && node scripts/remotion-cli.mjs render remotion/src/index.ts MoneyLoopMonth-Landscape remotion/out/money-loop-month-landscape.mp4 --codec=h264 --public-dir=remotion/public --overwrite",
    "studio:remotion": "node scripts/remotion-cli.mjs studio remotion/src/index.ts --public-dir=remotion/public",
    "sync:identity-doc": "node scripts/sync-identity-doc.mjs"
  },
  "devDependencies": {
    "@fontsource-variable/geist": "5.2.9",
    "@fontsource-variable/geist-mono": "5.2.8",
    "@fontsource-variable/literata": "5.2.8",
    "@remotion/bundler": "4.0.489",
    "@remotion/cli": "4.0.489",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "acorn": "8.17.0",
    "acorn-walk": "8.3.5",
    "gsap": "3.15.0",
    "hyperframes": "0.7.56",
    "parse5": "8.0.1",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "remotion": "4.0.489",
    "tsx": "4.23.1",
    "typescript": "6.0.3",
    "yaml": "2.9.0",
    "zod": "4.3.6"
  }
}
